{
  "name": "@legimi/database",
  "version": "0.1.0",
  "description": "Database layer with Prisma ORM",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "prisma studio",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "migrate": "prisma migrate dev",
    "migrate:prod": "prisma migrate deploy",
    "seed": "ts-node prisma/seed.ts",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "keywords": ["database", "prisma", "orm", "postgresql"],
  "author": "LEGIMI",
  "license": "PROPRIETARY",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "ts-node": "^10.9.1",
    "prisma": "^5.7.0"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0"
  }
}
