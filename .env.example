.env.local
.env.*.local
.env.production.local

# ============================================================
# SUPABASE (Free PostgreSQL, Auth, Realtime)
# ============================================================
# Get free account at: https://supabase.com
# Create new project (PostgreSQL included, 8GB free storage)

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_KEY=eyJhbGc...

# For local development (optional)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/legimi_commerce
SHADOW_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/legimi_commerce_shadow

# Redis (Optional - Supabase provides some free caching)
# For advanced use: https://vercel.com/storage/redis (free tier)
REDIS_URL=redis://localhost:6379

# OpenSearch
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_PASSWORD=LegimI@2024

# ============================================================
# STORAGE (Free Options)
# ============================================================
# Option 1: Supabase Storage (5GB free, included with Supabase)
# Already configured above with SUPABASE_URL

# Option 2: AWS S3 with Free Tier (12 months, 5GB/month)
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=us-east-1
S3_ACCESS_KEY=AKIA...
S3_SECRET_KEY=
S3_BUCKET=legimi-commerce-bucket

# Option 3: Cloudflare R2 (first 10GB/month free)
CLOUDFLARE_R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=

# Option 4: Local MinIO (completely free, self-hosted)
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin

# API Keys (Add your keys here)
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=24h
JWT_REFRESH_SECRET=change-me-in-production
JWT_REFRESH_EXPIRATION=7d

# ============================================================
# FREE AI SERVICES (All Free Tier - No Credit Card Required)
# ============================================================

# Groq API (Free - Fast LLM inference)
# Get free API key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_

# Hugging Face Inference API (Free - Image generation, text)
# Get free API key at: https://huggingface.co/settings/tokens
HUGGING_FACE_API_KEY=hf_

# Together AI (Free - LLM inference)
# Get free API key at: https://www.together.ai/
TOGETHER_API_KEY=

# Replicate API (Free - Image generation, ML models)
# Get free API key at: https://replicate.com/account/api-tokens
REPLICATE_API_KEY=

# Ollama (Local AI - Completely Free)
# Install from: https://ollama.ai
# Run: ollama run mistral
OLLAMA_URL=http://localhost:11434

# Stability AI (Free tier - Image generation)
# Get free credits at: https://platform.stability.ai/account/billing/overview
STABILITY_API_KEY=

# ============================================================
# PAYMENT KEYS (Use Stripe Free Testing or PayPal Sandbox)
# ============================================================
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLIC_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# ============================================================
# EMAIL SERVICE (Free Options)
# ============================================================
# Option 1: SendGrid (free tier: 100 emails/day)
# Get free at: https://sendgrid.com
SENDGRID_API_KEY=SG.

# Option 2: Resend (free tier: 100 emails/day)
# Get free at: https://resend.com
RESEND_API_KEY=re_

# Option 3: Mailgun (free tier: 1000 emails/month)
# Get free at: https://www.mailgun.com/
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# Option 4: Brevo (free tier: 300 emails/day)
# Get free at: https://www.brevo.com/
BREVO_API_KEY=

SENDER_EMAIL=noreply@legimi.commerce
SENDER_NAME=LEGIMI Commerce

# Frontend URLs
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STORE_URL=http://localhost:3002

# Backend URLs
API_URL=http://localhost:3001
INTERNAL_API_URL=http://api:3001

# ============================================================
# ANALYTICS & MONITORING (Free Options)
# ============================================================
# Option 1: Posthog (free tier: unlimited events, 1 project)
# https://posthog.com/
POSTHOG_API_KEY=phc_
POSTHOG_ENDPOINT=https://us.i.posthog.com

# Option 2: Mixpanel (free tier: 1000 events/month)
# https://mixpanel.com/
MIXPANEL_TOKEN=

# Option 3: Plausible (free tier: 200k events/month, privacy-focused)
# https://plausible.io/
PLAUSIBLE_API_KEY=

# Option 4: Vercel Analytics (free with Vercel hosting)
# Automatically included

# Features
ENABLE_AI=true
ENABLE_ANALYTICS=true
ENABLE_WEBHOOKS=true

# Node Environment
NODE_ENV=development
